# .chezmoiignore - Patterns for files that chezmoi should not manage
#
# FORMATTING RULES:
# - Use boxed headers (#######################################) to categorize groups
# - Always have 2 blank lines before each header section (except this first one)
# - No blank lines immediately after header lines
# - Entries are listed immediately following their section headers
# - Use descriptive category names in headers
#
# PATTERN SYNTAX:
# - Paths starting with / are relative to home directory
# - Use ** for recursive matching
# - Use ! to negate/include specific paths
# - Supports Go template conditionals (see Homebrew section example)


#######################################
# Homebrew
#######################################
{{- if ne .chezmoi.os "darwin" }}
Brewfile
{{ end }}

# The common/work entries are part of a template, dont copy to home
Brewfile.common
Brewfile.work


#######################################
# Claude
#######################################
/.claude/**/*
!/.claude/commands
!/.claude/commands/**
!/.claude/agents/**
!/.claude/skills
!/.claude/skills/**
!/.claude/settings.json
/.claude.json
/.claude.json.backup
/CLAUDE.md


#######################################
# Skills managed by workmux
# (installed directly to ~/.claude/skills/, not managed by chezmoi)
# Cannot be ignored here because ! negations take precedence.
# workmux, merge, rebase, worktree, coordinator, open-pr
#######################################


#######################################
# SSH Files
#######################################
/.ssh/*
!/.ssh/config


#######################################
# Zsh Caches
#######################################
!.oh-my-zsh/cache/.gitkeep
.oh-my-zsh/cache
**/*.zwc


