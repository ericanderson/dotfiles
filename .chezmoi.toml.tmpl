{{- $data := dict }}

{{- $email := "" -}}
{{- if (hasKey . "email") -}}
    {{- $_ := set $data "email" .email }}
{{-   $email = .email -}}
{{- else if (env "CODESPACES") -}}
{{- /* No need to set email in code spaces */ -}}
{{- else if (env "DOTFILES_EMAIL") -}}
{{-     $email = env "DOTFILES_EMAIL" -}}
{{- else -}}
{{-   $email = promptString "email" -}}
{{- end -}}


{{- if (hasKey . "signingKey") }}
    {{- $_ := set $data "signingKey" .signingKey }}
{{- end }}

{{- if (hasKey . "forceGitSigning") }}
    {{- $_ := set $data "forceGitSigning" .forceGitSigning }}
{{- end }}

{{- $isWork := regexMatch "^eanderson[0-9]+-mac$" .chezmoi.hostname }}
{{- $internalGitHost := "" }}
{{- if $isWork }}
{{-   if (hasKey . "internalGitHost") }}
{{-     $internalGitHost = .internalGitHost }}
{{-   else }}
{{-     $internalGitHost = promptString "internal git hostname (e.g. github.example.com)" }}
{{-   end }}
{{- end }}

[data]
    email = {{ $email | quote }}
    internalGitHost = {{ $internalGitHost | quote }}

{{- if (hasKey . "signingKey") }}
    signingKey = "{{ .signingKey }}"
{{- end }}
{{- if (hasKey . "forceGitSigning") }}
    forceGitSigning = "{{ .forceGitSigning }}"
{{- end }}

{{ dict "data2" $data | toToml }}
